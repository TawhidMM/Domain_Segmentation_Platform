# =================================================================
# APP SETTINGS
# =================================================================
APP_ENV=production
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=change_me_in_production

# =================================================================
# DATABASE CREDENTIALS (Postgres)
# =================================================================
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=db

# Internal Docker service names (usually stay as 'db' and 'redis')
DB_HOST=db
DB_PORT=5432

# =================================================================
# CACHE SETTINGS (Redis)
# =================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# =================================================================
# DOCKER / PERMISSIONS SETTINGS
# =================================================================
# On Linux, run 'getent group docker | cut -d: -f3' to find this
DOCKER_GID=984

# =================================================================
# HOST MACHINE PATHS
# =================================================================
# Absolute paths on your HOST machine where data should be persisted
HOST_EXPERIMENTS_ROOT=/path/to/your/project/backend/experiments
HOST_UPLOADS_ROOT=/path/to/your/project/backend/uploads